      "vertical-slice"
    ]
  },
  "text": {
    "ko": {
      "title": "글렌무어 협곡 전투",
      "objective": "전장의 적을 모두 섬멸하라.",
      "briefing": "베이르 대장이 방패 부대로 글렌무어 나루의 도하선을 틀어막았고, 하류에서는 예비대의 뿔나팔이 모여든다. 그들이 협곡을 봉쇄하기 전에 도하선을 돌파하라.",
      "victory": "베이르 대장이 쓰러지고 예비대의 뿔나팔도 꺾였다. 글렌무어 나루는 다시 우리의 것이다.",
      "defeat": "예비대의 압박에 도하선이 무너졌다. 글렌무어는 적의 깃발 아래 침묵한다.",
      "units": {
        "rowan": "로완",
        "elira": "엘리라",
        "sable": "세이블",
        "maelin": "마엘린",
        "osric": "오스릭",
        "talia": "탈리아",
        "brigandCaptain": "베이르 대장",
        "huntmaster": "늪지 사냥대장",
        "hexbinder": "주술 결박사",
        "shieldbearer": "방패병",
        "cutpurse": "소매치기",
        "fanatic": "재의 광신도",
        "fordStalker": "나루 추격병",
        "roadReaver": "대로 약탈자"
      },
      "phases": {
        "break-the-line": {
          "objective": "글렌무어 나루의 도하선을 지키는 방패대를 돌파하라."
        },
        "hunt-the-captain": {
          "objective": "나루 너머에서 예비대의 뿔나팔이 울린다. 도하선이 닫히기 전에 베이르 대장을 쓰러뜨려라.",
          "announcement": "나루 너머에서 예비대의 뿔나팔이 울린다. 베이르 대장이 모습을 드러냈다.",
          "victory": "예비대의 포위가 닫히기 전에 베이르 대장을 베어냈다. 글렌무어는 다시 숨을 쉬고 도하선은 열렸다.",
          "defeat": "예비대의 뿔나팔이 나루를 에워쌌고, 글렌무어는 도하선에서 협공에 짓눌렸다."
        }
      }
    },
    "en": {
      "title": "Skirmish at Glenmoor Pass",
      "objective": "Rout every enemy on the field.",
      "briefing": "Captain Veyr has locked the ford crossing behind a shielded guard while reserve horns gather downriver. Break the crossing before he can regroup and seal the pass.",
      "victory": "Captain Veyr is down, the reserve horn is broken, and Glenmoor Ford is ours again.",
      "defeat": "The crossing collapsed under the reserve push. Glenmoor falls silent beneath enemy banners.",
      "units": {
        "rowan": "Rowan",
        "elira": "Elira",
        "sable": "Sable",
        "maelin": "Maelin",
        "osric": "Osric",
        "talia": "Talia",
        "brigandCaptain": "Captain Veyr",
        "huntmaster": "Mire Huntmaster",
        "hexbinder": "Hexbinder",
        "shieldbearer": "Shieldbearer",
        "cutpurse": "Cutpurse",
        "fanatic": "Ash Fanatic",
        "fordStalker": "Ford Stalker",
        "roadReaver": "Road Reaver"
      },
      "phases": {
        "break-the-line": {
          "objective": "Break the crossing guard at Glenmoor Ford."
        },
        "hunt-the-captain": {
          "objective": "Reserve horns sound beyond the ford. Strike down Captain Veyr before the crossing closes.",
          "announcement": "Reserve horns are sounding beyond the ford. Captain Veyr is exposed.",
          "victory": "Veyr fell before the reserve trap could close. Glenmoor breathes again, and the ford stands open.",
          "defeat": "The reserve horn closed around the ford, and Glenmoor was crushed at the crossing."
        }
      }
    }
  },
